<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="EstudioContableApp.Views.DetalleClientePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="15">

        <Label Text="Detalle del cliente"
               FontSize="22"
               FontAttributes="Bold" />

        <Label Text="{Binding Nombre}" FontSize="18"/>
        <Label Text="{Binding Email}" FontSize="14"/>
        <Label Text="{Binding Vencimiento}" FontSize="14" TextColor="Red"/>
        <Label Text="Cliente activo" FontSize="12" TextColor="Green"/>
        
        <Label Text="Comprobante del cliente"
                   FontSize="18"
                   FontAttributes="Bold"
                   Margin="0,15,0,0"/>

        <Button Text="Seleccionar imagen de galería"
                    Command="{Binding SeleccionarImagenCommand}" />

        <Button Text="Tomar foto"
                    Command="{Binding TomarFotoCommand}" />

        <Image Source="{Binding ImagenComprobante}"
                   HeightRequest="220"
                   Aspect="AspectFit"
                   BackgroundColor="LightGray" />

            <Label Text="Ubicación del cliente"
                   FontSize="18"
                   FontAttributes="Bold"
                   Margin="0,15,0,0" />

            <Button Text="Obtener ubicación actual"
        Command="{Binding ObtenerUbicacionCommand}" />

            <Label Text="{Binding Ubicacion}"
                   FontSize="13"
                   TextColor="DarkSlateGray" />

            <Label Text="{Binding Mensaje}"
                   FontAttributes="Bold"
                   TextColor="Gray" />

    </VerticalStackLayout>
    </ScrollView>

</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="EstudioContableApp.Views.ClientesPage">

    <Grid Padding="20" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="15">

        <!-- titulo de la app -->
        <Label 
        Grid.Row="0"
        Text="Estudio Contable - Gestión de Clientes"
        FontSize="20"
        FontAttributes="Bold"
        HorizontalOptions="Center" />

        <!-- boton para consumir API -->
        <Button 
            Grid.Row="1"
            Text="Cargar clientes"
            BackgroundColor="#4CAF50"
            TextColor="White"
            Command="{Binding CargarClientesCommand}" />

        <!-- mensaje de estado (errores / info) -->
        <Label 
            Grid.Row="2"
            Text="{Binding Mensaje}" 
            FontAttributes="Bold"
            TextColor="Gray" />

        <!-- lista de clientes -->
        <CollectionView 
    Grid.Row="3"
    ItemsSource="{Binding Clientes}"
    SelectionMode="Single"
    SelectedItem="{Binding ClienteSeleccionado}">
            
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Stroke="LightGray" Padding="10" Margin="5">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="{Binding Nombre}" FontAttributes="Bold"/>
                            <Label Text="{Binding Email}" FontSize="12"/>
                            <Label Text="{Binding Vencimiento}" FontSize="11" TextColor="Red"/>

                            <Label 
                                Text="Cliente activo" 
                                FontSize="10" 
                                TextColor="Green"/>

                            <Button
    Text="Eliminar"
    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EliminarClienteCommand}"
    CommandParameter="{Binding .}"
    BackgroundColor="#D32F2F"
    TextColor="White"
    FontSize="12" />

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>